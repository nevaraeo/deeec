---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformGrid from '../components/PlatformGrid.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout
  title="页面未找到 404"
  description="抱歉，页面不存在。返回首页继续下载 Telegram 中文版。"
  noindex={true}
>
  <section class="container-page py-20 text-center">
    <p class="text-7xl font-bold text-tg-500">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-slate-900 sm:text-3xl">页面未找到</h1>
    <p class="mx-auto mt-3 max-w-md text-slate-600">
      你访问的页面不存在或已移动。可以从下方选择平台继续下载 Telegram（纸飞机）中文版。
    </p>
    <div class="mt-7 flex justify-center gap-3">
      <a href="/" class="btn btn-primary">返回首页</a>
      <a href="/downloads/" class="btn btn-ghost">下载中心 <Icon name="arrow" class="h-4 w-4" /></a>
    </div>
  </section>
  <section class="container-page section-tight">
    <PlatformGrid />
  </section>
  <div class="h-16"></div>
</BaseLayout>
