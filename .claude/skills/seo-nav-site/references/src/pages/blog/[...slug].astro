---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  const pool = [
    ...posts.map((e) => ({ type: 'blog' as const, e })),
    ...guides.map((e) => ({ type: 'guides' as const, e })),
  ];
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, pool } }));
}

const { post, pool } = Astro.props;
const d = post.data;
const { Content, headings } = await render(post);
const readingMinutes = Math.max(1, Math.round((post.body?.length ?? 0) / 400));

// 相关文章：按共享标签匹配，得分高者优先，排除自身
const myTags = new Set(d.tags);
const relatedPosts = pool
  .filter((x) => !(x.type === 'blog' && x.e.id === post.id))
  .map((x) => ({ x, score: x.e.data.tags.filter((t) => myTags.has(t)).length }))
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score || b.x.e.data.pubDate.getTime() - a.x.e.data.pubDate.getTime())
  .slice(0, 3)
  .map((r) => ({
    href: `/${r.x.type}/${r.x.e.id}/`,
    title: r.x.e.data.title,
    description: r.x.e.data.description,
    category: r.x.e.data.category,
    date: r.x.e.data.pubDate,
    tags: r.x.e.data.tags,
  }));

const crumbs = [
  { name: '首页', href: '/' },
  { name: '博客', href: '/blog/' },
  { name: d.title, href: `/blog/${post.id}/` },
];
const related = [
  { label: 'Telegram 电脑版下载', href: '/windows/' },
  { label: 'Telegram 安卓 APK 下载', href: '/android/' },
  { label: 'Telegram 中文设置教程', href: '/guides/telegram-chinese-language-pack/' },
  { label: '常见问题 FAQ', href: '/faq/' },
];
---
<ArticleLayout
  title={d.title}
  description={d.description}
  h1={d.title}
  pubDate={d.pubDate}
  updatedDate={d.updatedDate}
  author={d.author}
  category={d.category}
  readingMinutes={readingMinutes}
  tags={d.tags}
  crumbs={crumbs}
  faqs={d.faqs}
  related={related}
  relatedPosts={relatedPosts}
  keywords={d.tags}
  headings={headings}
  articleType="BlogPosting"
>
  <Content />
</ArticleLayout>
