---
import { SITE } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** 覆盖自动 canonical（一般不需要） */
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  keywords?: string[];
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  canonical,
  image = SITE.defaultOgImage,
  type = 'website',
  noindex = false,
  keywords = [],
  publishedTime,
  modifiedTime,
} = Astro.props;

// 自动 canonical：始终基于站点根 + 当前路径，保证唯一规范地址
const canonicalURL = canonical
  ? new URL(canonical, SITE.url)
  : new URL(Astro.url.pathname, SITE.url);

const ogImage = new URL(image, SITE.url).href;
---

<title>{title}</title>
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join('、')} />}
<link rel="canonical" href={canonicalURL.href} />

{
  noindex ? (
    <meta name="robots" content="noindex,follow" />
  ) : (
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
  )
}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content="zh_CN" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:site" content={SITE.twitter} />

<!-- 国际化 / 规范 -->
<link rel="alternate" hreflang="zh-CN" href={canonicalURL.href} />
<link rel="alternate" hreflang="x-default" href={canonicalURL.href} />
