---
interface Props {
  href: string;
  title: string;
  description: string;
  category?: string;
  date?: Date;
  tags?: string[];
}
const { href, title, description, category, date, tags = [] } = Astro.props;
const fmt = (d: Date) => new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="card card-hover flex flex-col">
  <div class="flex items-center gap-2 text-xs text-slate-500">
    {category && <span class="badge">{category}</span>}
    {date && <time>{fmt(date)}</time>}
  </div>
  <h3 class="mt-3 text-lg font-semibold leading-snug text-slate-900">
    <a href={href} class="no-underline hover:text-tg-600">{title}</a>
  </h3>
  <p class="mt-2 line-clamp-3 text-sm leading-6 text-slate-600">{description}</p>
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((t) => (
        <a href={`/tags/${encodeURIComponent(t)}/`} class="badge-slate no-underline hover:bg-slate-200">#{t}</a>
      ))}
    </div>
  )}
  <a href={href} class="mt-4 text-sm font-medium text-tg-600 no-underline hover:text-tg-700">阅读全文 →</a>
</article>
