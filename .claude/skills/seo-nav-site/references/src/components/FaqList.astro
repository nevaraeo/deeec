---
import Icon from './Icon.astro';
interface Props {
  faqs: { q: string; a: string }[];
  title?: string;
}
const { faqs, title = '常见问题（FAQ）' } = Astro.props;
---
<section class="container-page section-tight" aria-labelledby="faq-h">
  <h2 id="faq-h" class="text-2xl font-semibold text-slate-900 sm:text-3xl">{title}</h2>
  <div class="mt-6 divide-y divide-slate-200 overflow-hidden rounded-2xl border border-slate-200 bg-white">
    {faqs.map((f) => (
      <details class="group">
        <summary class="flex list-none items-center justify-between gap-4 px-5 py-4 text-[15px] font-medium text-slate-900 hover:bg-slate-50">
          <span>{f.q}</span>
          <Icon name="chevron" class="h-5 w-5 shrink-0 text-slate-400 transition-transform group-open:rotate-180" />
        </summary>
        <div class="px-5 pb-5 text-sm leading-7 text-slate-600">{f.a}</div>
      </details>
    ))}
  </div>
</section>
