---
import JsonLd from './JsonLd.astro';

interface Props {
  faqs: { q: string; a: string }[];
}
const { faqs } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
---
{faqs.length > 0 && <JsonLd schema={schema} />}
