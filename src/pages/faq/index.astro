---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import Cta from '../../components/Cta.astro';
import Icon from '../../components/Icon.astro';
import { CORE_FAQS } from '../../data/faqs';
import { getCollection } from 'astro:content';

const collection = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

const groups = [
  { category: '核心问题', faqs: CORE_FAQS },
  ...collection.map((c) => ({ category: c.data.title, faqs: c.data.faqs })),
];
const allFaqs = groups.flatMap((g) => g.faqs);

const title = 'Telegram 常见问题 FAQ - 下载/中文设置/安全';
const description =
  'Telegram（纸飞机）下载与使用常见问题解答：中文版怎么设置、APK 是否安全、电脑版是否需要手机在线、iOS 搜不到怎么办等。';
const crumbs = [
  { name: '首页', href: '/' },
  { name: '常见问题 FAQ', href: '/faq/' },
];
---
<BaseLayout title={title} description={description} keywords={['telegram常见问题','telegram中文设置','telegram apk安全','纸飞机faq']}>
  <Breadcrumbs items={crumbs} />

  <section class="container-page pt-8">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">常见问题（FAQ）</h1>
    <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
      关于 Telegram（纸飞机 / 飞机）下载、中文版设置与安全的高频问题，均按官方做法解答。
    </p>
  </section>

  {groups.map((g) => (
    <section class="container-page section-tight">
      <h2 class="text-xl font-semibold text-slate-900">{g.category}</h2>
      <div class="mt-5 divide-y divide-slate-200 overflow-hidden rounded-2xl border border-slate-200 bg-white">
        {g.faqs.map((f) => (
          <details class="group">
            <summary class="flex list-none items-center justify-between gap-4 px-5 py-4 text-[15px] font-medium text-slate-900 hover:bg-slate-50">
              <span>{f.q}</span>
              <Icon name="chevron" class="h-5 w-5 shrink-0 text-slate-400 transition-transform group-open:rotate-180" />
            </summary>
            <div class="px-5 pb-5 text-sm leading-7 text-slate-600">{f.a}</div>
          </details>
        ))}
      </div>
    </section>
  ))}

  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>
  <FaqSchema faqs={allFaqs} />
</BaseLayout>
