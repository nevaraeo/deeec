---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const blog = await getCollection('blog', ({ data }) => !data.draft);
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  const items = [
    ...blog.map((p) => ({ type: 'blog' as const, entry: p })),
    ...guides.map((p) => ({ type: 'guides' as const, entry: p })),
  ];
  const map = new Map<string, typeof items>();
  for (const it of items) {
    for (const t of it.entry.data.tags) {
      if (!map.has(t)) map.set(t, []);
      map.get(t)!.push(it);
    }
  }
  return [...map.entries()].map(([tag, list]) => ({ params: { tag }, props: { tag, list } }));
}

const { tag, list } = Astro.props;
const sorted = [...list].sort(
  (a, b) => b.entry.data.pubDate.getTime() - a.entry.data.pubDate.getTime()
);
const crumbs = [
  { name: '首页', href: '/' },
  { name: '标签', href: '/tags/' },
  { name: `#${tag}`, href: `/tags/${encodeURIComponent(tag)}/` },
];
---
<BaseLayout
  title={`#${tag} - Telegram 相关教程与文章`}
  description={`标签「${tag}」下的全部 Telegram（纸飞机）中文内容。`}
  keywords={[tag, 'telegram', '纸飞机']}
  noindex={true}
>
  <Breadcrumbs items={crumbs} />
  <section class="container-page pt-8">
    <p class="eyebrow">标签</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">#{tag}</h1>
    <p class="mt-3 text-sm text-slate-500">共 {sorted.length} 篇</p>
  </section>
  <section class="container-page section-tight">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map(({ type, entry }) => (
        <ArticleCard
          href={`/${type}/${entry.id}/`}
          title={entry.data.title}
          description={entry.data.description}
          category={entry.data.category}
          date={entry.data.pubDate}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>
</BaseLayout>
