---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const blog = await getCollection('blog', ({ data }) => !data.draft);
  const guides = await getCollection('guides', ({ data }) => !data.draft);

  const items = [
    ...blog.map((p) => ({ type: 'blog' as const, entry: p })),
    ...guides.map((p) => ({ type: 'guides' as const, entry: p })),
  ];
  const cats = new Map<string, typeof items>();
  for (const it of items) {
    const c = it.entry.data.category;
    if (!cats.has(c)) cats.set(c, []);
    cats.get(c)!.push(it);
  }
  return [...cats.entries()].map(([category, list]) => ({
    params: { category },
    props: { category, list },
  }));
}

const { category, list } = Astro.props;
const sorted = [...list].sort(
  (a, b) => b.entry.data.pubDate.getTime() - a.entry.data.pubDate.getTime()
);
const crumbs = [
  { name: '首页', href: '/' },
  { name: '分类', href: '/category/' },
  { name: category, href: `/category/${encodeURIComponent(category)}/` },
];
---
<BaseLayout
  title={`${category} - Telegram 中文教程分类`}
  description={`分类「${category}」汇总本站与 Telegram（纸飞机）相关的${category}文章，涵盖各平台下载、简体中文设置与使用技巧，内容专业、持续更新。`}
  keywords={[category, 'telegram教程', 'telegram中文']}
>
  <Breadcrumbs items={crumbs} />
  <section class="container-page pt-8">
    <p class="eyebrow">分类</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{category}</h1>
    <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
      「{category}」分类汇总了本站与 Telegram（中文俗称“纸飞机”）相关的{category}文章，涵盖各平台下载、简体中文设置与使用技巧，方便你系统地了解这一主题。本分类下的内容均基于 Telegram 官方做法编写，下载入口一律指向 telegram.org 官方源，力求权威、准确、可操作。
    </p>
    <p class="mt-3 text-sm text-slate-500">共 {sorted.length} 篇</p>
  </section>
  <section class="container-page section-tight">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map(({ type, entry }) => (
        <ArticleCard
          href={`/${type}/${entry.id}/`}
          title={entry.data.title}
          description={entry.data.description}
          category={entry.data.category}
          date={entry.data.pubDate}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>
</BaseLayout>
