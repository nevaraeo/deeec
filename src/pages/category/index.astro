---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';

const blog = await getCollection('blog', ({ data }) => !data.draft);
const guides = await getCollection('guides', ({ data }) => !data.draft);

const counts = new Map<string, number>();
for (const p of [...blog, ...guides]) {
  const c = p.data.category;
  counts.set(c, (counts.get(c) ?? 0) + 1);
}
const categories = [...counts.entries()].sort((a, b) => b[1] - a[1]);

const crumbs = [
  { name: '首页', href: '/' },
  { name: '分类', href: '/category/' },
];
---
<BaseLayout
  title="内容分类 - Telegram 中文教程与博客分类"
  description="按分类浏览 Telegram（纸飞机）中文下载教程、简体中文设置、安全使用与名词科普等专业内容，快速定位你需要的 Telegram 中文资料。"
  keywords={['telegram分类','telegram教程分类']}
>
  <Breadcrumbs items={crumbs} />
  <section class="container-page pt-8">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">内容分类</h1>
    <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
      按主题浏览本站全部 Telegram（中文俗称“纸飞机”）相关内容。下方分类汇总了下载指南、简体中文设置、安装教程、安全使用与名词科普等文章，帮助你快速找到所需的 Telegram 中文资料。
    </p>
    <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
      本站所有内容均围绕「安全、官方、可操作」编写:下载入口一律指向 telegram.org 官方源,教程基于官方做法,常见问题按官方说明解答。无论你是想下载 Telegram 电脑版、设置简体中文,还是了解纸飞机的安全用法,都能在对应分类下找到清晰、权威的指引。
    </p>
  </section>
  <section class="container-page section-tight">
    {categories.length === 0 ? (
      <p class="text-slate-500">暂无分类。</p>
    ) : (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map(([c, n]) => (
          <a href={`/category/${encodeURIComponent(c)}/`} class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-4 no-underline hover:border-tg-300">
            <span class="font-medium text-slate-800 group-hover:text-tg-700">{c}</span>
            <span class="badge-slate">{n} 篇 <Icon name="arrow" class="h-3.5 w-3.5" /></span>
          </a>
        ))}
      </div>
    )}
  </section>
  <div class="h-16"></div>
</BaseLayout>
