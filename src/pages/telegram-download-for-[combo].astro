---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DownloadButton from '../components/DownloadButton.astro';
import FaqList from '../components/FaqList.astro';
import FaqSchema from '../components/FaqSchema.astro';
import SoftwareAppSchema from '../components/SoftwareAppSchema.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import Cta from '../components/Cta.astro';
import { MATRIX } from '../data/matrix';
import { PLATFORMS } from '../data/platforms';

// Programmatic SEO：平台 × 系统版本 自动生成长尾下载页
export function getStaticPaths() {
  return MATRIX.map((m) => ({ params: { combo: m.combo }, props: { m } }));
}

const { m } = Astro.props;
const base = PLATFORMS[m.platform];

const crumbs = [
  { name: '首页', href: '/' },
  { name: '下载中心', href: '/downloads/' },
  { name: base.shortName, href: base.slug },
  { name: m.osVersion, href: `/telegram-download-for-${m.combo}/` },
];

const related = [
  { label: `${base.shortName}下载主页`, href: base.slug },
  { label: 'Telegram 中文版下载', href: '/telegram-chinese-download/' },
  { label: '纸飞机下载', href: '/paper-airplane-download/' },
  { label: 'Telegram 中文设置教程', href: '/guides/telegram-chinese-language-pack/' },
  { label: '常见问题 FAQ', href: '/faq/' },
  { label: '全部下载入口', href: '/downloads/' },
];
---
<BaseLayout title={m.title} description={m.description} keywords={m.keywords} type="article">
  <Breadcrumbs items={crumbs} />

  <section class="container-page pt-8">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-start">
      <div>
        <span class="badge">{m.osVersion} · 专版教程</span>
        <h1 class="mt-4 text-3xl font-bold leading-tight tracking-tight text-slate-900 sm:text-4xl">{m.h1}</h1>
        <p class="mt-4 max-w-xl text-base leading-7 text-slate-600">{m.intro}</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <DownloadButton href={base.downloadUrl} label={`下载 Telegram（${base.shortName}）`} sub={`官方版 v${base.version} · ${base.fileSize}`} />
          {base.altUrl && <DownloadButton href={base.altUrl} label={base.altLabel ?? '其它方式'} variant="ghost" />}
        </div>
      </div>
      <div class="card">
        <h2 class="text-sm font-semibold text-slate-900">{m.osVersion} 适配要点</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">{m.highlight}</p>
      </div>
    </div>
  </section>

  <section class="container-page section-tight">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">在 {m.osVersion} 上安装 Telegram 的步骤</h2>
    <ol class="mt-6 grid gap-4 sm:grid-cols-2">
      {base.steps.map((s, i) => (
        <li class="card flex gap-4">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-tg-500 text-sm font-bold text-white">{i + 1}</span>
          <div>
            <h3 class="text-base font-semibold text-slate-900">{s.title}</h3>
            <p class="mt-1 text-sm leading-6 text-slate-600">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="container-page section-tight">
    <div class="article max-w-3xl">
      <h2>关于 Telegram 与“纸飞机”</h2>
      <p>Telegram（中文用户常称“纸飞机”或“飞机”）是一款主打隐私与速度的跨平台即时通讯应用。本页所述“{m.osVersion} 版”并非独立软件，而是同一个 Telegram 官方客户端在 {m.osVersion} 上的安装说明。</p>
      <p>下载官方原版后，应用官方简体中文语言包即可获得 <strong>Telegram 中文版</strong> 界面，无需任何第三方汉化补丁。</p>
    </div>
  </section>

  <FaqList faqs={m.faqs} title={`Telegram ${m.osVersion} 下载常见问题`} />
  <RelatedLinks links={related} />

  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>

  <SoftwareAppSchema
    name={`Telegram（${m.osVersion}）`}
    os={m.osVersion}
    description={m.description}
    version={base.version}
    fileSize={base.fileSize}
    url={`/telegram-download-for-${m.combo}/`}
  />
  <FaqSchema faqs={m.faqs} />
</BaseLayout>
