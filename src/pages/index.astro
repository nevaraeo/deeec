---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PlatformGrid from '../components/PlatformGrid.astro';
import Section from '../components/Section.astro';
import FaqList from '../components/FaqList.astro';
import FaqSchema from '../components/FaqSchema.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Cta from '../components/Cta.astro';
import JsonLd from '../components/JsonLd.astro';
import SoftwareAppSchema from '../components/SoftwareAppSchema.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../data/site';
import { CORE_FAQS, DOWNLOAD_FAQS } from '../data/faqs';
import { PLATFORM_LIST } from '../data/platforms';
import { getCollection } from 'astro:content';

const blog = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Telegram 各平台下载',
  itemListElement: PLATFORM_LIST.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: new URL(p.slug, SITE.url).href,
  })),
};

const fmt = (d: string) => new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

const installSteps = [
  { t: '选择平台下载', d: '根据设备从本站官方入口获取安装包：Windows 电脑版、安卓 APK、iOS、Mac 或 Linux。' },
  { t: '安装应用', d: '按系统提示完成安装；安卓首次安装 APK 需对浏览器授予一次“安装未知应用”权限。' },
  { t: '手机号登录', d: '打开 Telegram 输入手机号接收验证码登录；已有账号会自动云端同步全部聊天记录。' },
  { t: '多端同步使用', d: '电脑、手机、平板可同时登录，消息云端实时同步，随时随地收发，无需手机常在线。' },
];

// HowTo 结构化数据：吃“如何下载/安装 Telegram”的富结果
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '如何下载并安装 Telegram',
  description: '无论电脑、安卓还是 iOS，从官方源下载安装 Telegram 只需四步。',
  totalTime: 'PT3M',
  step: installSteps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.t,
    text: s.d,
  })),
};

// 首页 FAQ：置顶“纸飞机=Telegram”实体等价直答（吃精选摘要），其余为纯下载意图问答
const homeFaqs = [CORE_FAQS[0], ...DOWNLOAD_FAQS];

// 页面级更新时间信号：取各平台最新更新日期（与 Hero、版本表同源）
const lastUpdated = PLATFORM_LIST.map((p) => p.updated).sort().at(-1) ?? '';
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${SITE.url}/#webpage`,
  url: `${SITE.url}/`,
  name: SITE.title,
  description: SITE.description,
  inLanguage: 'zh-CN',
  isPartOf: { '@id': `${SITE.url}/#website` },
  dateModified: lastUpdated,
};
---
<BaseLayout title={SITE.title} description={SITE.description} keywords={[...SITE.keywords]}>
  <Hero />

  <Section
    id="downloads"
    eyebrow="按平台下载"
    title="选择你的设备，立即下载 Telegram"
    lead="Windows 电脑版、安卓 APK、iOS、Mac、Linux —— 全部指向 telegram.org 官方源，安全无捆绑。"
  >
    <PlatformGrid />
  </Section>

  <Section
    eyebrow="版本信息"
    title="Telegram 各平台最新版本一览"
    lead="下表汇总了各平台官方客户端的最新版本信息、安装包大小及系统要求，数据将持续更新。所有下载链接均直接跳转至 Telegram 官方发布渠道，本站仅提供信息导航与下载指引，不存储、不分发任何安装文件。"
  >
    <div class="overflow-x-auto rounded-2xl border border-slate-200">
      <table class="w-full min-w-[680px] text-left text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-4 py-3 font-semibold">平台</th>
            <th class="px-4 py-3 font-semibold">最新版本</th>
            <th class="px-4 py-3 font-semibold">文件大小</th>
            <th class="px-4 py-3 font-semibold">系统要求</th>
            <th class="px-4 py-3 font-semibold">更新日期</th>
            <th class="px-4 py-3 text-right font-semibold">下载</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {PLATFORM_LIST.map((p) => (
            <tr class="hover:bg-slate-50/60">
              <td class="px-4 py-3 font-medium text-slate-900">{p.name}</td>
              <td class="px-4 py-3 text-slate-700">v{p.version}</td>
              <td class="px-4 py-3 text-slate-600">{p.fileSize}</td>
              <td class="px-4 py-3 text-slate-600">{p.requirements}</td>
              <td class="px-4 py-3 text-slate-500">{fmt(p.updated)}</td>
              <td class="px-4 py-3 text-right"><a href={p.slug} class="font-medium text-tg-600 no-underline hover:text-tg-700">{p.shortName} →</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-slate-500">版本号与体积为参考值，请以官方实际发布为准。Telegram 全平台免费，账号云端互通，可多端同时登录。</p>
    <p class="mt-2 text-sm"><a href="/blog/telegram-latest-version/" class="font-medium text-tg-600 no-underline hover:text-tg-700">查看各平台最新版本更新说明 →</a></p>
  </Section>

  <Section
    eyebrow="下载指南"
    title="如何下载并安装 Telegram（通用四步）"
    lead="无论电脑、安卓还是 iOS，下载安装 Telegram 只需四步，全程使用官方源，安全可靠。"
  >
    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {installSteps.map((s, i) => (
        <li class="card flex gap-4">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-tg-500 text-sm font-bold text-white">{i + 1}</span>
          <div>
            <h3 class="text-base font-semibold text-slate-900">{s.t}</h3>
            <p class="mt-1 text-sm leading-6 text-slate-600">{s.d}</p>
          </div>
        </li>
      ))}
    </ol>
    <p class="mt-4 flex items-center gap-2 text-xs text-slate-500">
      <Icon name="shield" class="h-4 w-4 text-tg-500" />
      安全提示：请只从 telegram.org 官方地址或 App Store / Google Play 下载，切勿安装第三方“汉化破解版”，以免账号被盗。详见
      <a href="/blog/telegram-download-safety/" class="text-tg-600 no-underline hover:text-tg-700">下载安全指南</a>
      与<a href="/guides/" class="text-tg-600 no-underline hover:text-tg-700">各平台安装教程</a>。
    </p>
  </Section>

  <Section eyebrow="关于 Telegram" title="关于 Telegram 与官方下载">
    <div class="article max-w-3xl">
      <p>Telegram（中文用户常称<a href="/paper-airplane-download/"><strong>“纸飞机”</strong></a>或<a href="/dianbao-download/"><strong>“电报”</strong></a>）是一款主打隐私、安全与速度的跨平台即时通讯应用，提供 Windows、macOS、Linux 桌面端与 Android、iOS 移动端官方客户端，<strong>完全免费</strong>。它支持云端多端同步、最多 20 万人的超大群组与频道、单文件最高 2GB 的传输，以及端到端加密的“秘密聊天”。</p>
      <p>下载 Telegram 请认准 <strong>telegram.org</strong> 官方域名，或通过 App Store / Google Play 获取。本站（telegramzhvip.com）汇总各平台官方下载入口，<strong>不托管安装包、不二次打包</strong>，确保你下载到安全无篡改的官方客户端。下载完成后，可按 <a href="/telegram-chinese/">Telegram 简体中文设置教程</a> 一键切换为中文界面。</p>
    </div>
  </Section>

  <Section
    eyebrow="功能特性"
    title="为什么选择 Telegram"
    lead="隐私优先、极速稳定、全平台云端互通 —— 这些核心能力让 Telegram 成为全球数亿用户的即时通讯首选。"
  >
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { i: 'lock', t: '端到端加密', d: '“秘密聊天”采用端到端加密、支持阅后即焚，配合两步验证，隐私牢牢掌握在自己手中。' },
        { i: 'bolt', t: '极速体验', d: '全球分布式服务器集群，消息与文件秒级送达，弱网环境下依然流畅稳定。' },
        { i: 'devices', t: '多端云同步', d: '手机、电脑、平板可同时在线，消息云端实时同步，换机登录即恢复，不丢记录。' },
        { i: 'users', t: '超大群组', d: '单个群组最多容纳 20 万人，支持管理员权限、话题分区与机器人自动化。' },
        { i: 'megaphone', t: '频道广播', d: '创建频道一对多发布内容，订阅人数无上限，轻松触达海量受众。' },
        { i: 'file', t: '大文件传输', d: '单个文件最高 2GB（Premium 4GB），发送视频、资料与安装包无需压缩。' },
        { i: 'cloud', t: '云端存储', d: '聊天记录与媒体文件存于 Telegram 云端，不占用本地空间，随时随地取用。' },
        { i: 'code', t: '开源透明', d: '客户端代码开源、通信协议公开，安全性可被全球开发者独立审计。' },
        { i: 'palette', t: '自由定制', d: '海量主题、贴纸与动画表情，聊天文件夹与界面布局随心定制。' },
      ].map((c) => (
        <div class="card">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-tg-50 text-tg-600"><Icon name={c.i as any} class="h-5 w-5" /></span>
          <h3 class="mt-4 text-base font-semibold text-slate-900">{c.t}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{c.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="为什么选择本站" title="安全、官方、快速">
    <div class="grid gap-4 sm:grid-cols-3">
      {[
        { i: 'shield', t: '官方源下载', d: '所有下载按钮直连 telegram.org，杜绝二次打包、捆绑插件与盗号风险。' },
        { i: 'download', t: '版本持续更新', d: '各平台版本号、文件体积与更新日期紧跟官方发布，始终提供最新正版安装包。' },
        { i: 'globe', t: '中文教程齐全', d: '各平台安装、简体中文设置、常见问题一站式解决。' },
      ].map((c) => (
        <div class="card">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-tg-50 text-tg-600"><Icon name={c.i as any} class="h-5 w-5" /></span>
          <h3 class="mt-4 text-base font-semibold text-slate-900">{c.t}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{c.d}</p>
        </div>
      ))}
    </div>
  </Section>

  {blog.length > 0 && (
    <Section eyebrow="教程推荐" title="最新中文教程与博客">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {blog.map((post) => (
          <ArticleCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            date={post.data.pubDate}
            tags={post.data.tags}
          />
        ))}
      </div>
      <div class="mt-8"><a href="/blog/" class="btn btn-ghost">查看全部博客 <Icon name="arrow" class="h-4 w-4" /></a></div>
    </Section>
  )}

  <Section eyebrow="完整指南" title="Telegram 下载与中文使用完整指南">
    <div class="article max-w-3xl">
      <p>这份完整指南把大家常搜的「Telegram下载」「纸飞机下载」「Telegram中文版下载」一次讲清，从名称由来、各平台下载、简体中文设置，到安全提示与新手中文使用，照着做即可<strong>安全、快速</strong>地用上 Telegram。本站所有下载入口均指向 <strong>telegram.org 官方源</strong>，只做信息导航，不托管、不二次打包任何安装文件。</p>

      <h3>Telegram、纸飞机、电报是什么关系</h3>
      <p>搜「纸飞机 App」找不到、搜「电报」又出来一堆别的？其实<strong>纸飞机、飞机、电报，说的都是同一款应用 —— Telegram</strong>。“纸飞机/飞机”源自它那架蓝色纸飞机图标，“电报”则是 telegram 的意译。所以「纸飞机下载」「电报下载」「Telegram中文版下载」本质上都是在下载同一个官方 Telegram，认准官方源即可。</p>

      <h3>“纸飞机下载”就是下载 Telegram</h3>
      <p>由于俗称的存在，网络上出现了不少蹭“纸飞机”名号的山寨包、汉化破解包，它们往往不是官方原版。正确做法依然是认准官方源下载官方 Telegram，再按需要切换中文。按设备直达官方下载页：<a href="/windows/">Telegram 电脑版下载</a>、<a href="/android/">安卓 APK</a>、<a href="/ios/">iOS / iPhone</a>、<a href="/mac/">Mac</a>、<a href="/linux/">Linux</a>，或免安装的 <a href="https://web.telegram.org/" target="_blank" rel="noopener">网页版</a>；全部入口见 <a href="/downloads/">下载中心</a>。</p>

      <h3>Telegram 中文版下载：没有单独的“中文版安装包”</h3>
      <p>这是最容易踩坑的一点：<strong>Telegram 官方并不提供单独的“中文版安装包”</strong>。官方客户端默认是英文，所谓「Telegram 中文版」= <strong>官方原版 + 官方简体中文语言包</strong>。正确流程是先从官方源装好官方原版，再应用官方简体中文语言包，界面即变为完整简体中文。千万不要为了“免设置中文”去下载第三方打包的“中文版.exe / 汉化版”，那是盗号高发区。延伸阅读 <a href="/telegram-chinese/">Telegram 中文版</a>。</p>

      <h3>Telegram 中文设置教程（界面汉化）</h3>
      <p>装好官方原版后，把界面变成简体中文只需一步：</p>
      <ol>
        <li>用浏览器打开本站提供的<strong>官方简体中文语言包</strong>深链；</li>
        <li>系统会唤起已安装的 Telegram，弹出语言包确认框；</li>
        <li>点击“应用 / Apply”，菜单、设置、按钮立即变为简体中文。</li>
      </ol>
      <p>这一步<strong>安全且可逆</strong>：它只改显示语言、不动客户端本体，日后在「设置 → Language（语言）」里随时能换回英文。完整图文见 <a href="/guides/telegram-chinese-language-pack/">Telegram 简体中文设置教程</a>。</p>

      <h3>安全下载提示：远离“汉化破解版”</h3>
      <p>网络上充斥着「Telegram 中文版破解 / 汉化绿色版 / 纸飞机破解版」这类二次打包文件，常被植入广告、后台程序，甚至窃取你的登录验证码导致<strong>账号被盗、好友被骗</strong>。判断是否官方很简单：</p>
      <ul>
        <li>下载地址是否为 <strong>telegram.org</strong>，或来自 App Store / Google Play；</li>
        <li>是否要求你关闭杀毒、授予异常权限；</li>
        <li>是否打着“免翻墙加速版 / 会员破解版”等噱头。</li>
      </ul>
      <p>正确做法永远是：<strong>官方原版 + 官方语言包</strong>，既是中文又安全。更多识别技巧见 <a href="/blog/telegram-download-safety/">Telegram 下载安全指南</a>。</p>

      <h3>Telegram 中文使用指南（新手入门）</h3>
      <p><strong>注册与登录：</strong>打开应用点 Start Messaging，选择国家区号、填入手机号，接收验证码后设置昵称即可。全程无需实名、无需身份证，只要一个能收验证码的手机号。</p>
      <p><strong>把账号变安全：</strong>在「设置 → 编辑资料 → 用户名」设一个 @username，别人搜用户名就能加你、不必透露手机号；再到「设置 → 隐私与安全 → 两步验证」设一个只有你知道的密码，这是防盗号最有效的一招。</p>
      <p><strong>加好友、建群与频道：</strong>可通过手机号、用户名或扫码添加联系人；在顶部搜索框输入关键词，或点别人给的 <code>t.me</code> 邀请链接即可加入。群组是双向群聊（最多 20 万人），频道是单向广播、订阅无上限。</p>
      <p><strong>多端同步与文件传输：</strong>电脑端登录后，手机和电脑实时同步，手机关机也不影响电脑收发；单个文件最高 2GB（Premium 4GB）。把消息转发给自己的“Saved Messages（收藏夹）”，还能当跨设备云笔记和剪贴板用。想系统学习更多用法，见 <a href="/blog/telegram-how-to-use/">Telegram 怎么用？新手入门完整指南</a>。</p>
    </div>
  </Section>

  <FaqList faqs={homeFaqs} title="Telegram 下载常见问题" />

  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>

  <FaqSchema faqs={homeFaqs} />
  <JsonLd schema={webPageSchema} />
  <JsonLd schema={itemListSchema} />
  <JsonLd schema={howToSchema} />
  <SoftwareAppSchema
    name="Telegram"
    os="Windows, macOS, Linux, Android, iOS"
    description={SITE.description}
    url="/"
    featureList={['云端多端同步', '最多 20 万人超大群组与频道', '端到端加密秘密聊天', '单文件最高 2GB 传输', '简体中文界面', '全平台免费']}
  />
</BaseLayout>
