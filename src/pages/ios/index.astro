---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PlatformDownloadView from '../../components/PlatformDownloadView.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import Cta from '../../components/Cta.astro';
import { PLATFORMS } from '../../data/platforms';
const data = PLATFORMS.ios;
const crumbs = [
  { name: '首页', href: '/' },
  { name: '下载', href: '/downloads/' },
  { name: 'iOS / iPhone', href: data.slug },
];
const related = [
  { label: 'Telegram 安卓 APK 下载', href: '/android/' },
  { label: 'Telegram Mac 下载', href: '/mac/' },
  { label: 'iOS 18 专版教程', href: '/telegram-download-for-ios-18/' },
  { label: 'iOS 17 专版教程', href: '/telegram-download-for-ios-17/' },
  { label: 'iPhone 中文设置教程', href: '/guides/telegram-chinese-language-pack/' },
  { label: '常见问题 FAQ', href: '/faq/' },
];
---
<BaseLayout title={data.title} description={data.description} keywords={data.keywords}>
  <Breadcrumbs items={crumbs} />
  <PlatformDownloadView data={data} />
  <RelatedLinks links={related} />
  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>
</BaseLayout>
