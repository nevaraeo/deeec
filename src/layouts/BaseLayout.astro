---
import '../styles/global.css';
import { SITE } from '../data/site';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  keywords?: string[];
  publishedTime?: string;
  modifiedTime?: string;
}
const {
  title,
  description,
  image,
  type = 'website',
  noindex = false,
  keywords = [],
  publishedTime,
  modifiedTime,
} = Astro.props;

// 全站知识图谱：Organization + WebSite（@id 关联，GEO / 实体 SEO 友好）
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE.url}/#organization`,
      name: SITE.name,
      alternateName: ['Telegram中文下载', 'telegrams.ltd', 'Telegram 纸飞机下载导航'],
      url: SITE.url,
      logo: {
        '@type': 'ImageObject',
        '@id': `${SITE.url}/#logo`,
        url: new URL(SITE.logo, SITE.url).href,
        width: 512,
        height: 512,
        caption: SITE.name,
      },
      image: { '@id': `${SITE.url}/#logo` },
      description: SITE.description,
      knowsAbout: [
        'Telegram',
        '纸飞机',
        'Telegram 中文版',
        'Telegram 下载',
        'Telegram 简体中文设置',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      name: SITE.name,
      url: SITE.url,
      inLanguage: 'zh-CN',
      description: SITE.description,
      publisher: { '@id': `${SITE.url}/#organization` },
    },
  ],
};
---
<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#229ed9" />
    <meta name="color-scheme" content="light" />
    <meta name="google-site-verification" content="ynGFUJOmEzl7z17XwjmZb6QkgbYrW6hW8KuqVcpMJWA" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      keywords={keywords}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />
    <JsonLd schema={orgSchema} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:shadow">跳到主内容</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
