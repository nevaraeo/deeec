---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqList from '../components/FaqList.astro';
import FaqSchema from '../components/FaqSchema.astro';
import JsonLd from '../components/JsonLd.astro';
import Cta from '../components/Cta.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../data/site';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface RelatedPost {
  href: string;
  title: string;
  description: string;
  category?: string;
  date?: Date;
  tags?: string[];
}
interface Props {
  title: string;
  description: string;
  h1: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  category?: string;
  difficulty?: string;
  readingMinutes?: number;
  tags?: string[];
  crumbs: { name: string; href: string }[];
  faqs?: { q: string; a: string }[];
  related?: { label: string; href: string }[];
  relatedPosts?: RelatedPost[];
  keywords?: string[];
  headings?: Heading[];
  articleType?: 'BlogPosting' | 'TechArticle' | 'HowTo';
}
const {
  title, description, h1, pubDate, updatedDate, author = SITE.publisher.name,
  category, difficulty, readingMinutes, tags = [], crumbs, faqs = [],
  related = [], relatedPosts = [], keywords = [], headings = [], articleType = 'BlogPosting',
} = Astro.props;

const fmt = (d: Date) => new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const authorInitial = author.trim().charAt(0).toUpperCase();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': articleType,
  headline: h1,
  description,
  inLanguage: 'zh-CN',
  image: [new URL(SITE.defaultOgImage, SITE.url).href],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: author, url: SITE.url },
  publisher: { '@id': `${SITE.url}/#organization` },
  isPartOf: { '@id': `${SITE.url}/#website` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  keywords: keywords.join(', '),
};
---
<BaseLayout
  title={title}
  description={description}
  type="article"
  keywords={keywords}
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
>
  <Breadcrumbs items={crumbs} />

  <div class="container-page pt-6">
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_15rem] lg:gap-12 xl:gap-16">
      <!-- 主体 -->
      <article class="min-w-0">
        <header class="border-b border-slate-200 pb-8">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
            {category && <span class="badge">{category}</span>}
            {difficulty && <span class="badge-slate">{difficulty}</span>}
            {readingMinutes && (
              <span class="inline-flex items-center gap-1 text-slate-400">
                <Icon name="bolt" class="h-3.5 w-3.5" /> 约 {readingMinutes} 分钟阅读
              </span>
            )}
          </div>
          <h1 class="mt-4 text-3xl font-bold leading-[1.15] tracking-tight text-slate-900 sm:text-[2.5rem]">{h1}</h1>
          <p class="mt-5 text-lg leading-8 text-slate-500">{description}</p>
          <div class="mt-7 flex items-center gap-3">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-gradient-to-b from-tg-400 to-tg-600 text-sm font-bold text-white">{authorInitial}</span>
            <div class="text-sm leading-tight">
              <div class="font-medium text-slate-800">{author}</div>
              <div class="mt-0.5 flex flex-wrap gap-x-3 text-xs text-slate-400">
                <time datetime={pubDate.toISOString()}>发布 {fmt(pubDate)}</time>
                {updatedDate && <time datetime={updatedDate.toISOString()}>更新 {fmt(updatedDate)}</time>}
              </div>
            </div>
          </div>
        </header>

        <!-- 移动端目录（折叠） -->
        {toc.length > 1 && (
          <details class="mt-6 rounded-xl border border-slate-200 bg-slate-50/60 lg:hidden">
            <summary class="flex list-none items-center justify-between px-4 py-3 text-sm font-semibold text-slate-800">
              本页目录 <Icon name="chevron" class="h-4 w-4 text-slate-400" />
            </summary>
            <nav class="border-t border-slate-200 px-4 py-3">
              <ul class="space-y-2 text-sm">
                {toc.map((h) => (
                  <li class={h.depth === 3 ? 'pl-4' : ''}>
                    <a href={`#${h.slug}`} class="text-slate-600 no-underline hover:text-tg-600">{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        )}

        <div class="article mt-10">
          <slot />
        </div>

        {tags.length > 0 && (
          <div class="mt-12 flex flex-wrap gap-2 border-t border-slate-200 pt-6">
            {tags.map((t) => (
              <a href={`/tags/${encodeURIComponent(t)}/`} class="badge-slate no-underline hover:bg-slate-200">#{t}</a>
            ))}
          </div>
        )}
      </article>

      <!-- 桌面端侧边目录 -->
      {toc.length > 1 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24" data-toc>
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">本页目录</p>
            <nav class="mt-4 border-l border-slate-200">
              <ul class="space-y-1 text-sm">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class:list={[
                        'toc-link -ml-px block border-l border-transparent py-1.5 leading-snug text-slate-500 no-underline transition-colors hover:text-tg-600',
                        h.depth === 3 ? 'pl-7' : 'pl-4 font-medium',
                      ]}
                    >{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>

  {faqs.length > 0 && <FaqList faqs={faqs} />}

  {relatedPosts.length > 0 && (
    <section class="container-page section-tight" aria-label="相关文章">
      <h2 class="text-xl font-semibold text-slate-900">相关文章</h2>
      <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {relatedPosts.map((p) => (
          <ArticleCard
            href={p.href}
            title={p.title}
            description={p.description}
            category={p.category}
            date={p.date}
            tags={p.tags}
          />
        ))}
      </div>
    </section>
  )}

  {related.length > 0 && <RelatedLinks links={related} />}

  <div class="mt-16"><Cta /></div>
  <div class="h-16"></div>

  <FaqSchema faqs={faqs} />
  <JsonLd schema={articleSchema} />
</BaseLayout>

<style>
  .toc-link[data-active] {
    color: var(--color-tg-700);
    border-color: var(--color-tg-500);
  }
</style>

<script is:inline>
  (() => {
    const links = Array.from(document.querySelectorAll('[data-toc] a'));
    if (!links.length) return;
    const byId = new Map(
      links.map((a) => [decodeURIComponent(a.getAttribute('href').slice(1)), a])
    );
    const heads = Array.from(document.querySelectorAll('.article h2, .article h3'));
    if (!heads.length) return;
    let current = null;
    const setActive = (id) => {
      if (id === current) return;
      current = id;
      links.forEach((l) => l.removeAttribute('data-active'));
      const a = byId.get(id);
      if (a) a.setAttribute('data-active', '');
    };
    const obs = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length) setActive(visible[0].target.id);
      },
      { rootMargin: '-80px 0px -65% 0px', threshold: 0 }
    );
    heads.forEach((h) => obs.observe(h));
  })();
</script>
