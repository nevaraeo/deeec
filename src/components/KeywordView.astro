---
import type { KeywordPage } from '../data/keywords';
import FaqList from './FaqList.astro';
import FaqSchema from './FaqSchema.astro';
import RelatedLinks from './RelatedLinks.astro';
import Cta from './Cta.astro';
import Icon from './Icon.astro';

interface Props {
  page: KeywordPage;
}
const { page } = Astro.props;
---
<section class="container-page pt-8">
  <div class="max-w-3xl">
    <span class="badge">Telegram · 纸飞机 · 飞机</span>
    <h1 class="mt-4 text-3xl font-bold leading-tight tracking-tight text-slate-900 sm:text-4xl">{page.h1}</h1>
    <p class="mt-5 text-base leading-7 text-slate-600">{page.lead}</p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a href="/downloads/" class="btn btn-lg btn-primary">查看全部下载入口 <Icon name="arrow" class="h-4 w-4" /></a>
    </div>
  </div>
</section>

<section class="container-page section-tight">
  <div class="article max-w-3xl">
    {page.sections.map((s) => (
      <>
        <h2>{s.heading}</h2>
        {s.paragraphs.map((p) => <p>{p}</p>)}
        {s.bullets && <ul>{s.bullets.map((b) => <li>{b}</li>)}</ul>}
      </>
    ))}
  </div>
</section>

<FaqList faqs={page.faqs} />
<RelatedLinks links={page.related} />
<div class="mt-16"><Cta /></div>
<div class="h-16"></div>

<FaqSchema faqs={page.faqs} />
