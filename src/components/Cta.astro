---
import Icon from './Icon.astro';
interface Props {
  title?: string;
  text?: string;
  primaryHref?: string;
  primaryLabel?: string;
}
const {
  title = '现在就下载 Telegram 中文版',
  text = '选择你的设备，从官方源安全下载，三步即可切换简体中文界面。',
  primaryHref = '/downloads/',
  primaryLabel = '查看全部下载入口',
} = Astro.props;
---
<section class="container-page">
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-tg-600 to-tg-800 px-6 py-12 sm:px-12 sm:py-16">
    <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-white/10"></div>
    <div class="relative max-w-2xl">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">{title}</h2>
      <p class="mt-3 text-base leading-7 text-tg-50">{text}</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href={primaryHref} class="btn btn-lg bg-white text-tg-700 hover:bg-tg-50">
          {primaryLabel} <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>
</section>
