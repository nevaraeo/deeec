---
import { NAV, SITE } from '../data/site';
import type { NavItem } from '../data/site';
import Icon from './Icon.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
const isParentActive = (item: NavItem) =>
  item.children
    ? isActive(item.href) ||
      item.children.some((c) => isActive(c.href)) ||
      path.startsWith('/telegram-download-for-')
    : isActive(item.href);
---
<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/85 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 no-underline" aria-label={`${SITE.name} 首页`}>
      <img src="/logo.svg" alt="Telegram" width="36" height="36" class="h-9 w-9" />
      <span class="text-[15px] font-semibold text-slate-900">Telegram</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="主导航">
      {NAV.map((item) =>
        item.children ? (
          <div class="group relative">
            <a
              href={item.href}
              class:list={[
                'inline-flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium no-underline transition-colors',
                isParentActive(item)
                  ? 'bg-tg-50 text-tg-700'
                  : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900',
              ]}
              aria-haspopup="true"
            >
              {item.label}
              <Icon name="chevron" class="h-4 w-4 transition-transform duration-150 group-hover:rotate-180" />
            </a>
            <!-- 下拉面板：悬停或键盘聚焦时显示（纯 CSS，零 JS） -->
            <div class="invisible absolute left-0 top-full z-50 pt-2 opacity-0 transition-opacity duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
              <div class="w-60 rounded-2xl border border-slate-200 bg-white p-2 shadow-xl ring-1 ring-black/5">
                {item.children.map((c) => (
                  <a
                    href={c.href}
                    class:list={[
                      'flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm font-medium no-underline transition-colors',
                      isActive(c.href) ? 'bg-tg-50 text-tg-700' : 'text-slate-700 hover:bg-slate-50 hover:text-tg-700',
                    ]}
                  >
                    {c.icon && (
                      <span class="grid h-7 w-7 shrink-0 place-items-center rounded-md bg-tg-50 text-tg-600">
                        <Icon name={c.icon as any} class="h-4 w-4" />
                      </span>
                    )}
                    {c.label}
                  </a>
                ))}
                <div class="my-1.5 border-t border-slate-100"></div>
                <a href={item.href} class="flex items-center justify-between rounded-lg px-3 py-2 text-sm font-medium text-tg-600 no-underline hover:bg-tg-50">
                  全部下载入口 <Icon name="arrow" class="h-4 w-4" />
                </a>
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium no-underline transition-colors',
              isActive(item.href) ? 'bg-tg-50 text-tg-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >{item.label}</a>
        )
      )}
    </nav>

    <div class="hidden lg:block">
      <a href="/downloads/" class="btn btn-primary">立即下载</a>
    </div>

    <!-- 移动端：纯 CSS 折叠菜单，零 JS -->
    <details class="relative lg:hidden">
      <summary class="grid h-10 w-10 list-none place-items-center rounded-lg border border-slate-200 text-slate-700" aria-label="打开菜单">
        <Icon name="menu" />
      </summary>
      <div class="absolute right-0 mt-2 w-64 rounded-2xl border border-slate-200 bg-white p-2 shadow-xl">
        {NAV.map((item) =>
          item.children ? (
            <details class="group">
              <summary class="flex list-none items-center justify-between rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50">
                {item.label}
                <Icon name="chevron" class="h-4 w-4 text-slate-400 transition-transform group-open:rotate-180" />
              </summary>
              <div class="ml-2 mt-0.5 border-l border-slate-100 pl-2">
                {item.children.map((c) => (
                  <a href={c.href} class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-600 no-underline hover:bg-slate-50 hover:text-tg-700">
                    {c.icon && <Icon name={c.icon as any} class="h-4 w-4 text-tg-500" />}
                    {c.label}
                  </a>
                ))}
                <a href={item.href} class="block rounded-lg px-3 py-2 text-sm font-medium text-tg-600 no-underline hover:bg-tg-50">全部下载入口 →</a>
              </div>
            </details>
          ) : (
            <a href={item.href} class="block rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 no-underline hover:bg-slate-50">{item.label}</a>
          )
        )}
        <a href="/downloads/" class="mt-1 block rounded-lg bg-tg-500 px-3 py-2.5 text-center text-sm font-semibold text-white no-underline">立即下载</a>
      </div>
    </details>
  </div>
</header>
