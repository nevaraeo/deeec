---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  lead?: string;
  tight?: boolean;
}
const { id, eyebrow, title, lead, tight = false } = Astro.props;
---
<section id={id} class:list={['container-page', tight ? 'section-tight' : 'section']}>
  {(eyebrow || title || lead) && (
    <div class="max-w-2xl">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      {title && <h2 class="mt-2 text-2xl font-semibold text-slate-900 sm:text-3xl">{title}</h2>}
      {lead && <p class="mt-3 text-base leading-7 text-slate-600">{lead}</p>}
    </div>
  )}
  <div class:list={[(eyebrow || title || lead) && 'mt-8']}>
    <slot />
  </div>
</section>
