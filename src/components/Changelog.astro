---
interface Entry {
  version: string;
  date: string | Date;
  notes: string[];
}
interface Props {
  entries: Entry[];
}
const { entries } = Astro.props;
const fmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---
<section class="container-page section-tight" aria-labelledby="changelog-h">
  <h2 id="changelog-h" class="text-2xl font-semibold text-slate-900 sm:text-3xl">更新日志</h2>
  <ol class="mt-6 space-y-5 border-l-2 border-slate-200 pl-6">
    {entries.map((e) => (
      <li class="relative">
        <span class="absolute -left-[31px] top-1.5 h-3 w-3 rounded-full border-2 border-white bg-tg-500"></span>
        <div class="flex flex-wrap items-baseline gap-3">
          <span class="badge">v{e.version}</span>
          <time class="text-xs text-slate-500">{fmt(e.date)}</time>
        </div>
        <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-600 marker:text-tg-400">
          {e.notes.map((n) => <li>{n}</li>)}
        </ul>
      </li>
    ))}
  </ol>
</section>
