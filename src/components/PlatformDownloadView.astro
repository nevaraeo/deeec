---
import type { PlatformData } from '../data/platforms';
import DownloadButton from './DownloadButton.astro';
import FaqList from './FaqList.astro';
import Changelog from './Changelog.astro';
import FaqSchema from './FaqSchema.astro';
import SoftwareAppSchema from './SoftwareAppSchema.astro';
import JsonLd from './JsonLd.astro';
import Icon from './Icon.astro';

interface Props {
  data: PlatformData;
}
const { data } = Astro.props;
const fmt = (d: string) => new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

// HowTo 结构化数据：逐平台安装步骤，吃“如何下载/安装 Telegram XXX”的富结果
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `如何下载并安装 ${data.name}`,
  description: `${data.shortName} 官方客户端的下载与安装步骤。`,
  step: data.steps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.title,
    text: s.body,
  })),
};
---
<!-- 头部：H1 + 下载 CTA -->
<section class="container-page pt-8 pb-4">
  <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-start">
    <div>
      <span class="badge">{data.requirements}</span>
      <h1 class="mt-4 text-3xl font-bold leading-tight tracking-tight text-slate-900 sm:text-4xl">{data.h1}</h1>
      <p class="mt-4 max-w-xl text-base leading-7 text-slate-600">{data.tagline}</p>

      <div class="mt-7 flex flex-wrap gap-3">
        <DownloadButton href={data.downloadUrl} label={`下载 ${data.shortName}`} sub={`官方版 v${data.version} · ${data.fileSize}`} />
        {data.altUrl && (
          <DownloadButton href={data.altUrl} label={data.altLabel ?? '其它方式'} variant="ghost" />
        )}
      </div>
    </div>

    <!-- 版本信息卡 -->
    <div class="card">
      <h2 class="text-sm font-semibold text-slate-900">版本信息</h2>
      <dl class="mt-4 space-y-3 text-sm">
        {[
          ['最新版本', `v${data.version}`],
          ['文件大小', data.fileSize],
          ['系统要求', data.requirements],
          ['更新日期', fmt(data.updated)],
          ['软件语言', '英文 / 简体中文（语言包）'],
          ['授权', '免费'],
        ].map(([k, v]) => (
          <div class="flex justify-between gap-4 border-b border-slate-100 pb-3 last:border-0 last:pb-0">
            <dt class="text-slate-500">{k}</dt>
            <dd class="text-right font-medium text-slate-900">{v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>

<!-- 介绍 -->
<section class="container-page section-tight">
  <div class="article max-w-3xl">
    <h2>{data.name} 介绍</h2>
    {data.intro.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- 功能特性 -->
<section class="container-page section-tight">
  <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">主要特性</h2>
  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {data.features.map((f) => (
      <div class="card">
        <span class="grid h-9 w-9 place-items-center rounded-lg bg-tg-50 text-tg-600"><Icon name="check" class="h-5 w-5" /></span>
        <h3 class="mt-3 text-base font-semibold text-slate-900">{f.title}</h3>
        <p class="mt-1.5 text-sm leading-6 text-slate-600">{f.body}</p>
      </div>
    ))}
  </div>
</section>

<!-- 安装教程 -->
<section class="container-page section-tight" aria-labelledby="howto">
  <h2 id="howto" class="text-2xl font-semibold text-slate-900 sm:text-3xl">安装教程（{data.shortName}）</h2>
  <ol class="mt-6 grid gap-4 sm:grid-cols-2">
    {data.steps.map((s, i) => (
      <li class="card flex gap-4">
        <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-tg-500 text-sm font-bold text-white">{i + 1}</span>
        <div>
          <h3 class="text-base font-semibold text-slate-900">{s.title}</h3>
          <p class="mt-1 text-sm leading-6 text-slate-600">{s.body}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<!-- 平台特有的权威语义内容 -->
{data.deepDive.length > 0 && (
  <section class="container-page section-tight">
    <div class="article max-w-3xl">
      {data.deepDive.map((b) => (
        <>
          <h2>{b.heading}</h2>
          {b.paragraphs.map((p) => <p>{p}</p>)}
        </>
      ))}
    </div>
  </section>
)}

<!-- 更新日志 -->
<Changelog entries={data.changelog} />

<!-- FAQ -->
<FaqList faqs={data.faqs} title={`${data.shortName} 下载常见问题`} />

<!-- Schema.org -->
<SoftwareAppSchema
  name={data.name}
  os={data.requirements}
  description={data.description}
  version={data.version}
  fileSize={data.fileSize}
  url={data.slug}
  featureList={data.features.map((f) => f.title)}
/>
<FaqSchema faqs={data.faqs} />
<JsonLd schema={howToSchema} />
